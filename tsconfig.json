{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "noEmit": true,
    "lib": ["es2025", "ESNext.Array", "ESNext.Collection", "ESNext.Iterator"],
    "types": ["node"]
  },
  "include": ["./"]
}
