{
  "name": "@changesets/format",
  "version": "0.1.0",
  "description": "Formats markdown generated by Changesets",
  "main": "dist/changesets-format.cjs.js",
  "module": "dist/changesets-format.esm.js",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/changesets-format.cjs.mjs",
        "default": "./dist/changesets-format.cjs.js"
      },
      "module": "./dist/changesets-format.esm.js",
      "import": "./dist/changesets-format.cjs.mjs",
      "default": "./dist/changesets-format.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "repository": "https://github.com/changesets/changesets/tree/main/packages/format",
  "dependencies": {
    "@changesets/types": "^6.1.0",
    "oxfmt": "^0.45.0",
    "prettier": "^2.7.1"
  }
}
